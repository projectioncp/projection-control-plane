# =============================================================================
# Projection Control Plane — Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in the values for your environment.
# Never commit .env.local to version control.
#
# Only the variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# All others are server-side only.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider — choose one (or add your own)
# The FrameProjector and ResponseSynthesizer implementations use these.
# -----------------------------------------------------------------------------

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# OpenAI (GPT) — optional, if you implement an OpenAI-backed projector
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Runtime Server
# The UI dashboard calls this to submit requests and stream execution events.
# Matches the baseUrl in src/lib/runtime/client.ts.
# -----------------------------------------------------------------------------

NEXT_PUBLIC_RUNTIME_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# LangGraph Checkpointer
# Persists conversation state across turns. Choose one backend.
#
# Option A — In-memory (default, no config needed, non-persistent)
# Option B — Redis
# Option C — PostgreSQL
# -----------------------------------------------------------------------------

# Redis checkpointer
REDIS_URL=

# PostgreSQL checkpointer
DATABASE_URL=

# -----------------------------------------------------------------------------
# Guardrail & Policy Engine (when implemented)
# -----------------------------------------------------------------------------

# Policy store connection — e.g. a config database or remote policy service
POLICY_STORE_URL=

# -----------------------------------------------------------------------------
# Audit & Observability (when implemented)
# -----------------------------------------------------------------------------

# Audit record sink — e.g. PostgreSQL, ClickHouse, or a logging service
AUDIT_DATABASE_URL=

# OpenTelemetry collector endpoint (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=
